Program.Sub.cmdMaintSaveMill.Start
V.Local.sSql.Declare(String)
V.Local.sComment.Declare(String)

F.ODBC.Connection!connect.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
F.ODBC.Connection!connect2.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)


'Search if the Mill Exist and if not Save it
V.Local.sSql.Set("Select * FROM GAB_Cert_Mill")
F.Intrinsic.String.Concat(V.Local.sSql," Where MillName='",V.Screen.FormMaint!txtMMill.Text,"'",V.Local.sSql)
F.ODBC.connection!connect.OpenRecordsetRO("Result",V.Local.sSql)
F.Intrinsic.Control.If(V.ODBC.connect!Result.EOF,=,True)
	V.Local.sSql.Set("SELECT * FROM GAB_Cert_Mill")
	F.ODBC.Connection!connect2.OpenRecordsetRW("Result2",V.Local.sSql)
	F.ODBC.connect2!Result2.AddNew
	F.ODBC.connect2!Result2.Set!MillName(V.Screen.FormMaint!txtMMill.Text)
	F.ODBC.connect2!Result2.Update
	F.Intrinsic.String.Concat("Mill:",V.Screen.FormMaint!txtMMill.Text," Saved",V.Local.sComment)
	F.Intrinsic.UI.Msgbox(V.Local.sComment)
	F.ODBC.connect2!Result2.Close
F.Intrinsic.Control.EndIf
F.ODBC.connect!Result.Close
F.ODBC.Connection!connect2.Close
F.ODBC.Connection!connect.Close

Program.Sub.cmdMaintSaveMill.End

Program.Sub.cmdMaintSaveGrade.Start
V.Local.sSql.Declare(String)
V.Local.sComment.Declare(String)

F.ODBC.Connection!connect.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
F.ODBC.Connection!connect2.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)


'Search if the Grade Type Exist and if not Save it
V.Local.sSql.Set("Select * FROM GAB_Cert_Grade")
F.Intrinsic.String.Concat(V.Local.sSql," Where GradeType='",V.Screen.FormMaint!txtMGrade.Text,"'",V.Local.sSql)
F.ODBC.connection!connect.OpenRecordsetRO("Result",V.Local.sSql)
F.Intrinsic.Control.If(V.ODBC.connect!Result.EOF,=,True)
	V.Local.sSql.Set("SELECT * FROM GAB_Cert_Grade")
	F.ODBC.Connection!connect2.OpenRecordsetRW("Result2",V.Local.sSql)
	F.ODBC.connect2!Result2.AddNew
	F.ODBC.connect2!Result2.Set!GradeType(V.Screen.FormMaint!txtMGrade.Text)
	F.ODBC.connect2!Result2.Update
	F.Intrinsic.String.Concat("Grade Type:",V.Screen.FormMaint!txtMGrade.Text," Saved",V.Local.sComment)
	F.Intrinsic.UI.Msgbox(V.Local.sComment)
	F.ODBC.connect2!Result2.Close
F.Intrinsic.Control.EndIf
F.ODBC.connect!Result.Close
F.ODBC.Connection!connect2.Close
F.ODBC.Connection!connect.Close


Program.Sub.cmdMaintSaveGrade.End

Program.Sub.cmdMaintDelGrade.Start
V.Local.sSql.Declare(String)
V.Local.sComment.Declare(String)

F.ODBC.Connection!connect.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
F.ODBC.Connection!connect2.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)


'Search if the Grade Type Exist and Delete it
V.Local.sSql.Set("Select * FROM GAB_Cert_Grade")
F.Intrinsic.String.Concat(V.Local.sSql," Where GradeType='",V.Screen.FormMaint!txtMGrade.Text,"'",V.Local.sSql)
F.ODBC.connection!connect.OpenRecordsetRO("Result",V.Local.sSql)
F.Intrinsic.Control.If(V.ODBC.connect!Result.EOF,=,False)
	F.ODBC.Connection!connect2.OpenRecordsetRW("Result2",V.Local.sSql)
	F.ODBC.connect2!Result2.Delete
	F.ODBC.connect2!Result2.Update
	F.Intrinsic.String.Concat("Grade Type:",V.Screen.FormMaint!txtMGrade.Text," Deleted",V.Local.sComment)
	F.Intrinsic.UI.Msgbox(V.Local.sComment)
	Gui.FormMaint.txtMGrade.Text("")
	F.ODBC.connect2!Result2.Close
F.Intrinsic.Control.EndIf
F.ODBC.connect!Result.Close
F.ODBC.Connection!connect2.Close
F.ODBC.Connection!connect.Close



Program.Sub.cmdMaintDelGrade.End

Program.Sub.cmdMaintDelMill.Start
V.Local.sSql.Declare(String)
V.Local.sComment.Declare(String)

F.ODBC.Connection!connect.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
F.ODBC.Connection!connect2.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)


'Search if the Mill Exist and delete it
V.Local.sSql.Set("Select * FROM GAB_Cert_Mill")
F.Intrinsic.String.Concat(V.Local.sSql," Where MillName='",V.Screen.FormMaint!txtMMill.Text,"'",V.Local.sSql)
F.ODBC.connection!connect.OpenRecordsetRO("Result",V.Local.sSql)
F.Intrinsic.Control.If(V.ODBC.connect!Result.EOF,=,False)
	F.ODBC.Connection!connect2.OpenRecordsetRW("Result2",V.Local.sSql)
	F.ODBC.connect2!Result2.Delete
	F.ODBC.connect2!Result2.Update
	F.Intrinsic.String.Concat("Mill:",V.Screen.FormMaint!txtMMill.Text," Deleted",V.Local.sComment)
	F.Intrinsic.UI.Msgbox(V.Local.sComment)
	Gui.FormMaint.txtMMill.Text("")
	F.ODBC.connect2!Result2.Close
F.Intrinsic.Control.EndIf
F.ODBC.connect!Result.Close
F.ODBC.Connection!connect2.Close
F.ODBC.Connection!connect.Close



Program.Sub.cmdMaintDelMill.End

Program.Sub.Val_OD.Start
V.Local.fTemp.Declare(Float)

' Validate OD Field
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtOD.Text,"<>","")
	F.Intrinsic.Math.Round(V.Screen.frmMTR_Entry!txtOD.Text,3,V.Local.fTemp)
	F.Intrinsic.String.Format(V.Local.fTemp,"###.000",Variable.Local.fTemp)
	Gui.frmMTR_Entry.txtOD.Text(V.Local.fTemp)
F.Intrinsic.Control.EndIf
' Validate Wall Thickness
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtWall.Text,"<>","")
	F.Intrinsic.Math.Round(V.Screen.frmMTR_Entry!txtWall.Text,3,V.Local.fTemp)
	F.Intrinsic.String.Format(V.Local.fTemp,"###.000",Variable.Local.fTemp)
	Gui.frmMTR_Entry.txtWall.Text(V.Local.fTemp)
F.Intrinsic.Control.EndIf

Program.Sub.Val_OD.End

Program.Sub.Val_YieldStrength.Start
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtYieldStrength.Text,"<>","")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtYieldStrength.Text,">",10000)
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtYieldStrength.Text,"=>",300000)
			F.Intrinsic.UI.Msgbox("Yield Strength value isn't valid, is greater, must be > 10000 and <300000")
			Gui.frmMTR_Entry.txtYieldStrength.SetFocus
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		F.Intrinsic.UI.Msgbox("Yield Strength value isn't valid, is lower, must be > 10000 and <300000")
		Gui.frmMTR_Entry.txtYieldStrength.SetFocus
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf

Program.Sub.Val_YieldStrength.End

Program.Sub.Val_TensileStrength.Start
'Validate Tensile Strength
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtTensileStrength.Text,"<>","")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtTensileStrength.Text,">",10000)
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtTensileStrength.Text,"=>",300000)
			F.Intrinsic.UI.Msgbox("Tensile Strength value must fall between > 10000 and <300000, is higher.")
			Gui.frmMTR_Entry.txtTensileStrength.SetFocus
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		F.Intrinsic.UI.Msgbox("Tensile Strength value must fall between > 10000 and <300000, is lower.")
		Gui.frmMTR_Entry.txtTensileStrength.SetFocus
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf

'Validate Yield and Tensile Strength
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtTensileStrength.Text,"<>","")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtYieldStrength.Text,"<>","")
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtYieldStrength.Text,>,V.Screen.frmMTR_Entry!txtTensileStrength.Text)
			F.Intrinsic.UI.Msgbox("Check your tensile values. Yield strength should be lower than tensile strength.")
			Gui.frmMTR_Entry.txtYieldStrength.Text("")
			Gui.frmMTR_Entry.txtYieldStrength.SetFocus
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf


Program.Sub.Val_TensileStrength.End

Program.Sub.Val_PerctElong.Start
'Validate Percent Elongation
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtPercElong.Text,"<>","")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtPercElong.Text,"<",0)
		F.Intrinsic.UI.Msgbox("Percent Elongation value must >= 0, is negative.")
		Gui.frmMTR_Entry.txtTensileStrength.SetFocus
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf

Program.Sub.Val_PerctElong.End

