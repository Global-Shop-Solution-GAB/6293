Program.Sub.cmdMaintBrwMill.Start
V.Local.sTitles.Declare(String)
V.Local.iWidths.Declare(Long)
V.Local.sRet.Declare(String)

'Browser for select Mill from table
F.ODBC.Connection!conx.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
V.Local.sTitles.Set("Mill")
V.Local.iWidths.Set("4600")
F.Intrinsic.UI.MiniBrowser("Select a Mill Name",conx,"Select MillName From GAB_Cert_Mill",V.Local.sTitles,V.Local.iWidths,V.Local.sRet)
F.Intrinsic.Control.If(V.Local.sRet,"=","***CANCEL***")
	F.Intrinsic.UI.Msgbox("No Mill was selected")
F.Intrinsic.Control.Else
	F.Intrinsic.String.Split(V.Local.sRet,"*!*",V.Local.sRet)
	Gui.FormMaint.txtMMill.Text(V.Local.sRet)
F.Intrinsic.Control.EndIf
F.ODBC.Connection!conx.Close



