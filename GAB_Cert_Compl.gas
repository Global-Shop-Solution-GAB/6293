Program.Sub.Val_Mg.Start
'Validate Mg
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtMg.Text,"<>","")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtMg.Text,">",0)
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtMg.Text,"=>",1)
			F.Intrinsic.UI.Msgbox("Magnesium (Mg) must fall between 0 and 1")
			Gui.frmMTR_Entry.txtMg.SetFocus
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		F.Intrinsic.UI.Msgbox("Magnesium (Mg) must fall between 0 and 1")
		Gui.frmMTR_Entry.txtMg.SetFocus
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf

Program.Sub.Val_Mg.End

