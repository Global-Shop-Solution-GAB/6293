Program.Sub.brwMill.Start
V.Local.sTitles.Declare(String)
V.Local.iWidths.Declare(Long)
V.Local.sRet.Declare(String)

'Browser for select Mill from table
F.ODBC.Connection!conx.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
V.Local.sTitles.Set("Mill")
V.Local.iWidths.Set("4600")
F.Intrinsic.UI.MiniBrowser("Select a Mill Name",conx,"Select MillName From GAB_Cert_Mill",V.Local.sTitles,V.Local.iWidths,V.Local.sRet)
F.Intrinsic.Control.If(V.Local.sRet,"=","***CANCEL***")
	F.Intrinsic.UI.Msgbox("No Mill was selected")
F.Intrinsic.Control.Else
	F.Intrinsic.String.Split(V.Local.sRet,"*!*",V.Local.sRet)
	Gui.frmMTR_Entry.txtMill.Text(V.Local.sRet)
F.Intrinsic.Control.EndIf
F.ODBC.Connection!conx.Close

F.Intrinsic.Control.CallSub(F_autoselmill)

Program.Sub.brwMill.End

Program.Sub.F_AutoSelMill.Start
'Check if the Mill is valid for Mill setup
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtMill.Text,=,"Flame")
	F.Intrinsic.Control.CallSub(Cmdflame)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"NSS")
	F.Intrinsic.Control.CallSub(Cmdnssvm)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"Koppel")
	F.Intrinsic.Control.CallSub(Cmdkoppel)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"Nippon")
	F.Intrinsic.Control.CallSub(Cmdnippon)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"PetroTub")
	F.Intrinsic.Control.CallSub(Cmdpetrotub)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"SilcoTub")
	F.Intrinsic.Control.CallSub(Cmdsilcotub)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"TAMSA")
	F.Intrinsic.Control.CallSub(Cmdtamsa)
F.Intrinsic.Control.ElseIf(V.Screen.frmMTR_Entry!txtMill.Text,=,"USS")
	F.Intrinsic.Control.CallSub(Cmduss)
F.Intrinsic.Control.EndIf

Program.Sub.F_AutoSelMill.End

