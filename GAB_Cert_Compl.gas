Program.Sub.brwRecord.Start
V.Local.sTitles.Declare(String)
V.Local.iWidths.Declare(Long)
V.Local.sRet.Declare(String)

'Browser for select Record from table
F.ODBC.Connection!conx.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)
F.Intrinsic.String.Split("Record*!*Order Number*!*Mill*!*Lincoln Heat No*!*Heat Number","*!*",V.Local.sTitles)
'V.Local.sTitles.Set("Mill")
F.Intrinsic.String.Split("1000*!*2500!*2500*!*2000*!*2000","*!*",V.Local.iWidths)

'V.Local.iWidths.Set("2000")
F.Intrinsic.UI.Browser("Select a Record",conx,"Select Record,TestOrderNumber,Mill,LincolnHeat,HeatNumber From GAB_Cert_MillCert Order by Record Desc",V.Local.sTitles,V.Local.iWidths,V.Local.sRet)
F.ODBC.Connection!conx.Close
F.Intrinsic.Control.If(V.Local.sRet,"=","***CANCEL***")
	F.Intrinsic.UI.Msgbox("No Record was selected")
F.Intrinsic.Control.Else
	F.Intrinsic.String.Split(V.Local.sRet,"*!*",V.Local.sRet)
	Gui.frmMTR_Entry.lblRecord.Caption(V.Local.sRet(0))
	F.Intrinsic.Control.CallSub(F_load_form)
F.Intrinsic.Control.EndIf

Program.Sub.brwRecord.End

