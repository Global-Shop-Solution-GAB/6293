Program.Sub.F_Calc_CharpyAVG.Start
V.Local.fCharpy1.Declare(Float)
V.Local.fCharpy2.Declare(Float)
V.Local.fCharpy3.Declare(Float)
V.Local.fCharpyAvg.Declare(Float)
V.Local.fCharpy1.Set(V.Screen.frmMTR_Entry!txtCharpy1.Text)
V.Local.fCharpy2.Set(V.Screen.frmMTR_Entry!txtCharpy2.Text)
V.Local.fCharpy3.Set(V.Screen.frmMTR_Entry!txtCharpy3.Text)

Gui.frmMTR_Entry.txtCharpyAvg.Text("")
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtCharpy1.Text,<>,"")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtCharpy2.Text,<>,"")
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtCharpy3.Text,<>,"")
			F.Intrinsic.Math.Add(V.Local.fCharpy1,V.Local.fCharpy2,V.Local.fCharpy3,V.Local.fCharpyAvg)
			F.Intrinsic.Math.Div(V.Local.fCharpyAvg,3,V.Local.fCharpyAvg)
			F.Intrinsic.Math.Round(V.Local.fCharpyAvg,1,V.Local.fCharpyAvg)
			Gui.frmMTR_Entry.txtCharpyAvg.Text(V.Local.fCharpyAvg)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf

Program.Sub.F_Calc_CharpyAVG.End

Program.Sub.F_Calc_ShearAVG.Start
V.Local.fShear1.Declare(Float)
V.Local.fShear2.Declare(Float)
V.Local.fShear3.Declare(Float)
V.Local.fShearAvg.Declare(Float)
V.Local.fShear1.Set(V.Screen.frmMTR_Entry!txtShear1.Text)
V.Local.fShear2.Set(V.Screen.frmMTR_Entry!txtShear2.Text)
V.Local.fShear3.Set(V.Screen.frmMTR_Entry!txtShear3.Text)

Gui.frmMTR_Entry.txtShearAvg.Text("")
F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtShear1.Text,<>,"")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtShear2.Text,<>,"")
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtShear3.Text,<>,"")
			F.Intrinsic.Math.Add(V.Local.fShear1,V.Local.fShear2,V.Local.fShear3,V.Local.fShearAvg)
			F.Intrinsic.Math.Div(V.Local.fShearAvg,3,V.Local.fShearAvg)
			F.Intrinsic.Math.Round(V.Local.fShearAvg,1,V.Local.fShearAvg)
			Gui.frmMTR_Entry.txtShearAvg.Text(V.Local.fShearAvg)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndIf


Program.Sub.F_Calc_ShearAVG.End

Program.Sub.F_Calc_AvgHardness.Start
V.Local.lMwid.Declare(Long)
V.Local.fMW1.Declare(Float)
V.Local.fMW2.Declare(Float)
V.Local.fMW3.Declare(Float)
V.Local.fMWSum.Declare(Float)
V.Local.fOD1.Declare(Float)
V.Local.fOD2.Declare(Float)
V.Local.fOD3.Declare(Float)
V.Local.lOdid.Declare(Long)
V.Local.fODSum.Declare(Float)
V.Local.fID1.Declare(Float)
V.Local.fID2.Declare(Float)
V.Local.fID3.Declare(Float)
V.Local.lIdid.Declare(Long)
V.Local.fIDSum.Declare(Float)
V.Local.fAvgHardness1.Declare(Float)
V.Local.fAvgHardnessDiv.Declare(Long)

F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtAvgHardness.Text,=,"")
	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTMW1.Text,<>,"")
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTMW2.Text,<>,"")
			F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTMW3.Text,<>,"")
				V.Local.fMW1.Set(V.Screen.frmMTR_Entry!txtHTMW1.Text)
				V.Local.fMW2.Set(V.Screen.frmMTR_Entry!txtHTMW2.Text)
				V.Local.fMW3.Set(V.Screen.frmMTR_Entry!txtHTMW3.Text)
				F.Intrinsic.Math.Add(V.Local.fMW1,V.Local.fMW2,V.Local.fMW3,V.Local.fMWSum)
				V.Local.lMwid.Set(1)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTOD1.Text,<>,"")
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTOD2.Text,<>,"")
			F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTOD3.Text,<>,"")
				V.Local.fMW1.Set(V.Screen.frmMTR_Entry!txtHTOD1.Text)
				V.Local.fMW2.Set(V.Screen.frmMTR_Entry!txtHTOD2.Text)
				V.Local.fMW3.Set(V.Screen.frmMTR_Entry!txtHTOD3.Text)
				F.Intrinsic.Math.Add(V.Local.fOD1,V.Local.fOD2,V.Local.fOD3,V.Local.fODSum)
				V.Local.lOdid.Set(1)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTID1.Text,<>,"")
		F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTID2.Text,<>,"")
			F.Intrinsic.Control.If(V.Screen.frmMTR_Entry!txtHTID3.Text,<>,"")
				V.Local.fMW1.Set(V.Screen.frmMTR_Entry!txtHTID1.Text)
				V.Local.fMW2.Set(V.Screen.frmMTR_Entry!txtHTID2.Text)
				V.Local.fMW3.Set(V.Screen.frmMTR_Entry!txtHTID3.Text)
				F.Intrinsic.Math.Add(V.Local.fID1,V.Local.fID2,V.Local.fID3,V.Local.fIDSum)
				V.Local.lIdid.Set(1)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.If(V.Local.lMwid,=,1)
	F.Intrinsic.Control.If(V.Local.lOdid,=,1)
			F.Intrinsic.Control.If(V.Local.lIdid,=,1)
				F.Intrinsic.Math.Add(V.Local.fIDSum,V.Local.fODSum,V.Local.fMWSum,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Div(V.Local.fAvgHardness1,9,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Round(V.Local.fAvgHardness1,2,V.Local.fAvgHardness1)
				Gui.frmMTR_Entry.txtAvgHardness.Text(V.Local.fAvgHardness1)
			F.Intrinsic.Control.Else
				F.Intrinsic.Math.Add(V.Local.fODSum,V.Local.fMWSum,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Div(V.Local.fAvgHardness1,6,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Round(V.Local.fAvgHardness1,2,V.Local.fAvgHardness1)
				Gui.frmMTR_Entry.txtAvgHardness.Text(V.Local.fAvgHardness1)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Else
			F.Intrinsic.Control.If(V.Local.lIdid,=,1)
				F.Intrinsic.Math.Add(V.Local.fIDSum,V.Local.fMWSum,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Div(V.Local.fAvgHardness1,6,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Round(V.Local.fAvgHardness1,2,V.Local.fAvgHardness1)
				Gui.frmMTR_Entry.txtAvgHardness.Text(V.Local.fAvgHardness1)
			F.Intrinsic.Control.Else
				V.Local.fAvgHardness1.Set(V.Local.fMWSum)
				F.Intrinsic.Math.Div(V.Local.fAvgHardness1,3,V.Local.fAvgHardness1)
				F.Intrinsic.Math.Round(V.Local.fAvgHardness1,2,V.Local.fAvgHardness1)
				Gui.frmMTR_Entry.txtAvgHardness.Text(V.Local.fAvgHardness1)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		F.Intrinsic.UI.Msgbox("Incomplete Harness Data. Please input a minimun of 3 mid-wall readings.")
	F.Intrinsic.Control.EndIF
F.Intrinsic.Control.EndIF

Program.Sub.F_Calc_AvgHardness.End

Program.Sub.cmdSave.Start
V.Local.sSql.Declare(String)
V.Local.lRec.Declare(Long)
V.Local.lRec.set(1)
V.Local.sComment.Declare(String)

F.ODBC.Connection!connect.OpenConnection(V.Ambient.PDSN,V.Ambient.PUser,V.Ambient.PPass)

'Search for the last Record in the GAB_Cert_MillCert table and get the next number
V.Local.sSql.Set("Select MAX(Record) AS 'REC' FROM GAB_Cert_MillCert")
F.ODBC.connection!connect.OpenRecordsetRO("Result",V.Local.sSql)
F.Intrinsic.Control.If(V.ODBC.connect!Result.EOF,=,False)
	V.Local.lRec.Set(V.ODBC.connect!Result.FieldVal!REC)
	F.Intrinsic.Math.Add(V.Local.lRec,1,V.Local.lRec)
F.Intrinsic.Control.EndIf
F.ODBC.connect!Result.Close

'Save Values to the table
V.Local.sSql.Set("SELECT * FROM GAB_Cert_MillCert")
F.ODBC.Connection!connect.OpenRecordsetRW("Result",V.Local.sSql)
F.ODBC.connect!Result.AddNew
F.ODBC.connect!Result.Set!Mill(V.Screen.frmMTR_Entry!txtMill.Text)
